# cypod-telemetry — copy to .env and fill in real values
# Postgres connection string used by Prisma (datasource: USERS_DATABASE_URL)
USERS_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/telemetry_db"

# Auth
JWT_SECRET="change-me-to-a-32+-character-random-secret"
JWT_EXPIRES_IN="24h"

# Server
PORT=3000
FRONTEND_URL="http://localhost:5173"

# Cache (Redis)
REDIS_HOST="localhost"
REDIS_PORT=6379
