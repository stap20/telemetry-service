# cypod-telemetry — copy to .env and fill in real values
# Per-module Postgres databases (each module owns an isolated DB — see PrismaConnectionBase)
AUTH_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_db"
DEVICES_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/devices_db"

# Auth
JWT_SECRET="change-me-to-a-32+-character-random-secret"
JWT_EXPIRES_IN="24h"

# Server
PORT=3000
FRONTEND_URL="http://localhost:5173"

# Cache (Redis)
REDIS_HOST="localhost"
REDIS_PORT=6379

# How long a cached "latest state" stays valid. See the README for why 1 hour.
TELEMETRY_LATEST_STATE_TTL_SECONDS=3600

# Alert thresholds. Battery below / temperature above these raises an alert.
TELEMETRY_MIN_BATTERY=15
TELEMETRY_MAX_TEMPERATURE=60

# Rate limiting. The first is the task's 10-per-minute rule, measured against the minute each
# reading DESCRIBES so an offline device can still flush its backlog — see the README.
TELEMETRY_MAX_READINGS_PER_MINUTE=10
# Backstop on raw request volume per device per wall-clock minute. Not the rule above; this only
# exists to bound a device fabricating timestamps spread across many distinct minutes.
TELEMETRY_MAX_REQUESTS_PER_MINUTE=600
