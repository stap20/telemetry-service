// cypod-telemetry
generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

// note: `id` is client-supplied (the physical device's own stable identity) — no @default, because
// incoming telemetry references the device by the same id the client registers here. `ownerId` is
// the authenticated user's id, stored as a plain string with NO foreign key to the auth database:
// each module owns its own DB (modular monolith), so cross-module identity is carried by value, not
// by a join. Indexed because `GET /devices` always filters by owner.
model Device {
  id        String   @id
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("devices")
}

// note: one immutable row per accepted reading — the raw event log. `id` is server-generated (a
// reading has no natural external identity, unlike Device.id which the physical device carries).
// `deviceId` is stored by value with NO foreign key: same modular-monolith rule as Device.ownerId —
// telemetry could later move to its own DB, so cross-concept identity is a plain string, not a join.
// battery is a whole percent (0-100); temperature/lat/lng are floats. Indexed by (deviceId,
// recordedAt) because every read is "the latest readings for one device".
model TelemetryEvent {
  id          String   @id
  deviceId    String
  battery     Int
  temperature Float
  lat         Float
  lng         Float
  status      String
  recordedAt  DateTime
  createdAt   DateTime @default(now())

  @@index([deviceId, recordedAt])
  @@map("telemetry_events")
}

// note: alerts are persisted (not just logged) so a breach is auditable and queryable — a future
// GET /devices/:id/alerts drops straight in. Written by the alert event-handler reacting to a
// TelemetryThresholdBreachedEvent, NOT on the ingestion write path: raising the alert is a
// downstream side effect, so the POST stays fast and a failing alert never rejects a valid reading.
// `value` is the reading that breached, `threshold` the limit it crossed; both kept for the record.
model Alert {
  id          String   @id
  deviceId    String
  type        String
  message     String
  value       Float
  threshold   Float
  triggeredAt DateTime
  createdAt   DateTime @default(now())

  @@index([deviceId, createdAt])
  @@map("alerts")
}
